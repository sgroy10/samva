+async function callCron(path) {
+  try {
+    const resp = await client.post(path, {}, { timeout: 120000 });
+    return resp.data;
+  } catch (err) {
+    console.error(`[CoreClient] Cron ${path} failed:`, err.message);
+    return {};
+  }
+}
